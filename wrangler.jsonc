{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "buddylandscaping",
    "compatibility_date": "2026-05-04",
    "observability": {
      "enabled": true
    },
    "compatibility_flags": [
      "nodejs_compat"
    ],
    "services": [
      {
        "binding": "WORKER_SELF_REFERENCE",
        "service": "buddylandscaping"
      }
    ]
  }